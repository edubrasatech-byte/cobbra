# ==========================================
# Cobbra — Variáveis de Ambiente (Template)
# ==========================================

# Chave de API do Google Gemini (Essencial para Catarina AI & Copilot)
# Obtenha sua chave gratuita em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# Segredo do JWT para controle de sessões e cookies seguros
# Use uma hash complexa ou string aleatória de pelo menos 32 caracteres em produção
JWT_SECRET=cobroo-secret-key-2026-CHANGE-ME-IN-PROD-use-32-chars-minimum

# Configuração da Evolution API para envio real de mensagens de WhatsApp
# Deixe em branco para usar o simulador em Base64 local interativo de custo zero
NEXT_PUBLIC_EVOLUTION_API_URL=
EVOLUTION_API_GLOBAL_TOKEN=

# URL Base do Site (Canonical SEO)
NEXT_PUBLIC_BASE_URL=https://cobbra.ai
